#!/bin/bash
# Ghostty Quick Config — CachyOS/Hyprland Edition
# Usage: gconfig [preset|theme|font|status]

GHOSTTY_DIR="$HOME/.config/ghostty"
CONFIG_FILE="$GHOSTTY_DIR/config"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
PURPLE='\033[0;35m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

show_help() {
    echo -e "${CYAN}${BOLD}Ghostty Config Switcher${NC} ${DIM}(CachyOS/Hyprland)${NC}"
    echo ""
    echo -e "${YELLOW}Presets${NC} (theme + font combos):"
    echo -e "  ${GREEN}gconfig cyber${NC}     Tokyo Night + Fira Code"
    echo -e "  ${GREEN}gconfig minimal${NC}   Nord + Iosevka"
    echo -e "  ${GREEN}gconfig cozy${NC}      Gruvbox + JetBrains Mono"
    echo -e "  ${GREEN}gconfig pro${NC}       Dracula + Cascadia Code"
    echo ""
    echo -e "${YELLOW}Themes${NC} (colors only):"
    echo -e "  ${GREEN}gconfig theme tokyo-night${NC}"
    echo -e "  ${GREEN}gconfig theme catppuccin-mocha${NC}"
    echo -e "  ${GREEN}gconfig theme dracula${NC}"
    echo -e "  ${GREEN}gconfig theme nord${NC}"
    echo -e "  ${GREEN}gconfig theme gruvbox${NC}"
    echo ""
    echo -e "${YELLOW}Fonts${NC}:"
    echo -e "  ${GREEN}gconfig font jetbrains-mono${NC}"
    echo -e "  ${GREEN}gconfig font fira-code${NC}"
    echo -e "  ${GREEN}gconfig font cascadia-code${NC}"
    echo -e "  ${GREEN}gconfig font iosevka${NC}"
    echo -e "  ${GREEN}gconfig font monaspace-neon${NC}"
    echo ""
    echo -e "${YELLOW}Other${NC}:"
    echo -e "  ${GREEN}gconfig status${NC}    Show current config"
    echo -e "  ${GREEN}gconfig reset${NC}     Restore default config"
}

apply_preset() {
    local preset_file="$GHOSTTY_DIR/presets/$1.conf"
    if [[ ! -f "$preset_file" ]]; then
        echo -e "${RED}Preset '$1' not found.${NC}"
        return 1
    fi

    # Read the base config to preserve keybinds and system settings
    local keybinds_section
    keybinds_section=$(sed -n '/^# ===.*Keyboard/,$p' "$CONFIG_FILE")

    # Build new config: header + preset values + keybinds
    {
        echo "# Ghostty Configuration -- CachyOS/Hyprland Edition"
        echo "# Active preset: $1"
        echo "# Managed via ~/.dotfiles, symlinked to ~/.config/ghostty"
        echo ""
        echo "# Dynamic theme colors (omarchy fallback)"
        echo "config-file = ?\"~/.config/omarchy/current/theme/ghostty.conf\""
        echo ""
        cat "$preset_file"
        echo ""
        echo "# Window system"
        echo "window-theme = ghostty"
        echo "confirm-close-surface = false"
        echo "resize-overlay = never"
        echo "gtk-toolbar-style = flat"
        echo ""
        echo "# Cursor blink"
        echo "cursor-style-blink = false"
        echo ""
        echo "# Shell integration"
        echo "shell-integration-features = no-cursor,ssh-env"
        echo ""
        echo "# Mouse"
        echo "mouse-scroll-multiplier = 0.95"
        echo ""
        echo "# Hyprland performance fix"
        echo "async-backend = epoll"
        echo ""
        echo "$keybinds_section"
    } > "$CONFIG_FILE"

    echo -e "${GREEN}Applied preset: ${BOLD}$1${NC}"
    echo -e "${DIM}Restart Ghostty to see changes${NC}"
}

apply_theme() {
    local theme_file="$GHOSTTY_DIR/themes/$1.conf"
    if [[ ! -f "$theme_file" ]]; then
        echo -e "${RED}Theme '$1' not found.${NC}"
        return 1
    fi

    # Extract theme name and selection-background from theme file
    local theme_name selection_bg
    theme_name=$(grep '^theme' "$theme_file" | head -1 | cut -d= -f2 | xargs)
    selection_bg=$(grep '^selection-background' "$theme_file" | head -1 | cut -d= -f2 | xargs)

    # Update in-place
    sed -i "s/^theme = .*/theme = $theme_name/" "$CONFIG_FILE"
    if [ -n "$selection_bg" ]; then
        if grep -q '^selection-background' "$CONFIG_FILE"; then
            sed -i "s/^selection-background = .*/selection-background = $selection_bg/" "$CONFIG_FILE"
        else
            sed -i "/^theme = /a selection-background = $selection_bg" "$CONFIG_FILE"
        fi
    fi

    echo -e "${GREEN}Applied theme: ${BOLD}$theme_name${NC}"
    echo -e "${DIM}Restart Ghostty to see changes${NC}"
}

apply_font() {
    local font_file="$GHOSTTY_DIR/fonts/$1.conf"
    if [[ ! -f "$font_file" ]]; then
        echo -e "${RED}Font '$1' not found.${NC}"
        return 1
    fi

    # Read font settings
    local font_family font_thicken font_feature
    font_family=$(grep '^font-family' "$font_file" | head -1 | cut -d= -f2 | xargs)
    font_thicken=$(grep '^font-thicken' "$font_file" | head -1 | cut -d= -f2 | xargs)
    font_feature=$(grep '^font-feature' "$font_file" | head -1 | cut -d= -f2 | xargs)

    # Update in-place
    sed -i "s/^font-family = .*/font-family = \"$font_family\"/" "$CONFIG_FILE"
    sed -i "s/^font-thicken = .*/font-thicken = $font_thicken/" "$CONFIG_FILE"
    if [ -n "$font_feature" ]; then
        if grep -q '^font-feature' "$CONFIG_FILE"; then
            sed -i "s/^font-feature = .*/font-feature = $font_feature/" "$CONFIG_FILE"
        else
            sed -i "/^font-thicken/a font-feature = $font_feature" "$CONFIG_FILE"
        fi
    fi

    echo -e "${GREEN}Applied font: ${BOLD}$font_family${NC}"
    echo -e "${DIM}Restart Ghostty to see changes${NC}"
}

show_status() {
    echo -e "${CYAN}${BOLD}Current Ghostty Config${NC}"
    echo ""
    echo -e "  Theme:     ${GREEN}$(grep '^theme' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')${NC}"
    echo -e "  Font:      ${GREEN}$(grep '^font-family' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')${NC}"
    echo -e "  Size:      ${GREEN}$(grep '^font-size' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')${NC}"
    echo -e "  Cursor:    ${GREEN}$(grep '^cursor-style ' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')${NC}"
    echo -e "  Padding:   ${GREEN}$(grep '^window-padding-x' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')x$(grep '^window-padding-y' "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2 | xargs || echo 'default')${NC}"
    echo ""
    echo -e "  ${DIM}Config: $CONFIG_FILE${NC}"
}

reset_config() {
    cd "$GHOSTTY_DIR" || exit 1
    git checkout -- config 2>/dev/null || {
        echo -e "${RED}Could not reset. Restore manually from dotfiles repo.${NC}"
        return 1
    }
    echo -e "${GREEN}Config reset to default.${NC}"
}

# Route
case "${1:-}" in
    cyber|cyberpunk)    apply_preset "cyberpunk-dev" ;;
    minimal|min)        apply_preset "minimal-focus" ;;
    cozy)               apply_preset "cozy-coding" ;;
    pro|professional)   apply_preset "professional-elegant" ;;
    theme)              apply_theme "${2:-}" ;;
    font)               apply_font "${2:-}" ;;
    status|current)     show_status ;;
    reset)              reset_config ;;
    *)                  show_help ;;
esac
